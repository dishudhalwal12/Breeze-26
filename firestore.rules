rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // Business profiles: only the authenticated owner can read/write their own data
    match /businessProfiles/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders: authenticated users can only access their own orders
    match /orders/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Products/catalog: authenticated users can only access their own catalog
    match /products/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
